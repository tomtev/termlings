{
  "version": 1,
  "himalaya": {
    "binary": "himalaya",
    "configPath": "~/.config/himalaya/config.toml"
  },
  "project": {
    "account": "team",
    "folder": "INBOX",
    "from": "Team <team@example.com>",
    "requiredEnv": [
      "TEAM_EMAIL_PASSWORD"
    ]
  },
  "agents": {
    "developer": {
      "account": "developer",
      "folder": "INBOX",
      "from": "Developer <developer@example.com>",
      "requiredEnv": [
        "DEV_EMAIL_PASSWORD"
      ]
    }
  }
}
